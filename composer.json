{
    "name": "otrd/brightcove-api-wrapper",
    "description": "Brightcove PHP API Wrapper",
    "keywords": ["brightcove", "api"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Tamás Demeter-Haludka",
            "homepage": "https://github.com/tamasd"
        },
        {
            "name": "KonczGabor",
            "homepage": "https://github.com/KonczGabor"
        },
        {
            "name": "janmashat",
            "homepage": "https://github.com/janmashat"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "~11.5.39",
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.2"
    },
    "require": {
        "php": "8.2.*",
        "ext-curl": "*"
    },
    "autoload": {
        "psr-4": {
            "Brightcove\\": "lib/Brightcove/",
            "Brightcove\\Test\\": "test/Brightcove/Test/"
        }
    },
    "scripts": {
        "fix": "php vendor/bin/php-cs-fixer fix",
        "phpstan": "php -d memory_limit=-1 vendor/bin/phpstan analyse",
        "pr-check": [
            "@fix",
            "@phpstan"
        ]
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0.x-dev"
        }
    }
}
